---
const year = new Date().getFullYear();
---

<footer class="border-t border-line/70 px-6 py-10">
  <div class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
    <p class="font-display text-lg italic text-ink">
      bljeona<span class="text-coral">.</span>
    </p>

    <p class="font-mono text-xs uppercase tracking-wider text-ink-soft">
      © {year} Bljeona · built static · portfolio
    </p>

    <div class="flex gap-5 font-mono text-xs uppercase tracking-wider">
      <a href="https://github.com/bljeona" class="link-grow hover:text-coral">
        GitHub
      </a>
      <a
        href="https://www.linkedin.com/in/bljeona"
        class="link-grow hover:text-coral"
      >
        LinkedIn
      </a>
    </div>
  </div>
</footer>