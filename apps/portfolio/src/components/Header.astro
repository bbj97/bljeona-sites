---
const links = [
  { href: "#about", label: "About" },
  { href: "#skills", label: "Skills" },
  { href: "#work", label: "Work" },
  { href: "#contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-line/70 bg-paper/80 backdrop-blur-md">
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4"
    aria-label="Primary"
  >
    <a
      href="#top"
      class="font-display text-2xl font-black italic tracking-tight text-ink"
    >
      bljeona<span class="text-coral">.</span>
    </a>

    <ul class="hidden items-center gap-8 text-sm font-medium text-ink-soft sm:flex">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="link-grow transition-colors hover:text-ink">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href="https://hub.bljeona.com"
      class="rounded-full border-2 border-ink bg-ink px-4 py-1.5 font-mono text-xs uppercase tracking-wider text-paper transition-transform hover:-translate-y-0.5"
    >
      AltSource Hub ↗
    </a>
  </nav>
</header>