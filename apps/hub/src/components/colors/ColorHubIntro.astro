<header class="top">
  <div>
    <p class="tagline">
      Start with one brand color. Add more when needed. Build even OKLCH scales,
      check contrast, and copy ready-to-use tokens.
    </p>
  </div>
  <div class="presets" aria-label="Preset colors">
    <span class="p-label">Presets</span>
    <button
      type="button"
      class="dot"
      style="--preset:#ef6351"
      data-hex="#ef6351"
      aria-label="Use coral preset"></button>
    <button
      type="button"
      class="dot"
      style="--preset:#2e7d5b"
      data-hex="#2e7d5b"
      aria-label="Use green preset"></button>
    <button
      type="button"
      class="dot"
      style="--preset:#3b6ea5"
      data-hex="#3b6ea5"
      aria-label="Use blue preset"></button>
    <button
      type="button"
      class="dot"
      style="--preset:#8b5cf6"
      data-hex="#8b5cf6"
      aria-label="Use violet preset"></button>
    <button
      type="button"
      class="dot"
      style="--preset:#d4a017"
      data-hex="#d4a017"
      aria-label="Use ochre preset"></button>
    <button
      type="button"
      class="dot"
      style="--preset:#0f766e"
      data-hex="#0f766e"
      aria-label="Use teal preset"></button>
  </div>
</header>
