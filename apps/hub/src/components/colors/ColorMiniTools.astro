<section aria-labelledby="mini-tools-title">
  <div class="section-head">
    <h2 id="mini-tools-title">Small color tools</h2>
    <span class="hint">Fast checks for the selected palette.</span>
  </div>
  <div class="mini-grid">
    <article class="mini-card">
      <div class="mini-card-head">
        <h3>Color inspector</h3>
        <p>Copy common formats for the active color.</p>
      </div>
      <div class="inspector-values" id="inspectorValues"></div>
    </article>
    <article class="mini-card">
      <div class="mini-card-head">
        <h3>Accessible pairs</h3>
        <p>Text and background pairs from this scale that pass AA.</p>
      </div>
      <div class="pair-list" id="pairList" aria-live="polite"></div>
    </article>
    <article class="mini-card">
      <div class="mini-card-head">
        <h3>Gradient helper</h3>
        <p>Build a calm gradient from the active scale.</p>
      </div>
      <div
        class="gradient-preview"
        id="gradientPreview"
        aria-label="Gradient preview"
      >
      </div>
      <div class="gradient-controls">
        <div class="ck-row">
          <label for="gradientStart">From</label>
          <select id="gradientStart"></select>
        </div>
        <div class="ck-row">
          <label for="gradientEnd">To</label>
          <select id="gradientEnd"></select>
        </div>
      </div>
      <div class="gradient-code" id="gradientCode"></div>
      <button class="btn mini-action" id="copyGradient" type="button"
        >Copy CSS</button
      >
    </article>
  </div>
</section>
