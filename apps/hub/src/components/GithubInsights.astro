---
const GITHUB_TOKEN = import.meta.env.GITHUB_TOKEN;
const USERNAME = "bbj97";
const YEAR = new Date().getFullYear();

interface LangSlice {
    name: string;
    share: number;
}

let languages: LangSlice[] = [];
let scanned = 0;
let lastCommit: Date | null = null;
let rhythm = {
    peakWindow: "Quiet Evening",
    hours: "6 PM – 12 AM",
    offHoursPct: 0,
};
let velocity = {
    yearly: 0,
    spike: 0,
    longestStreak: 0,
    dayPreference: "Mid-week Focus",
};
let collab = { style: "Independent Craft", prs: 0, reviews: 0 };

function relTime(from: Date, now: Date = new Date()): string {
    const s = Math.max(0, Math.floor((now.getTime() - from.getTime()) / 1000));
    if (s < 45) return "just now";
    const m = Math.floor(s / 60);
    if (s < 90) return "1 minute ago";
    if (m < 60) return `${m} minutes ago`;
    const h = Math.floor(m / 60);
    if (m < 90) return "1 hour ago";
    if (h < 24) return `${h} hours ago`;
    const d = Math.floor(h / 24);
    if (h < 36) return "1 day ago";
    if (d < 7) return `${d} days ago`;
    const w = Math.floor(d / 7);
    if (d < 11) return "1 week ago";
    if (w < 5) return `${w} weeks ago`;
    const mo = Math.floor(d / 30);
    if (d < 45) return "1 month ago";
    if (mo < 12) return `${mo} months ago`;
    const y = Math.floor(d / 365);
    return y <= 1 ? "1 year ago" : `${y} years ago`;
}

if (GITHUB_TOKEN) {
    try {
        const response = await fetch("https://api.github.com/graphql", {
            method: "POST",
            headers: {
                Authorization: `Bearer ${GITHUB_TOKEN}`,
                "Content-Type": "application/json",
                "User-Agent": "Astro-Portfolio-Insights",
            },
            body: JSON.stringify({
                query: `
          query ($username: String!) {
            user(login: $username) {
              repositories(ownerAffiliations: OWNER, isFork: false, orderBy: { field: PUSHED_AT, direction: DESC }, first: 100) {
                nodes {
                  pushedAt
                  languages(first: 10, orderBy: { field: SIZE, direction: DESC }) {
                    edges { size node { name } }
                  }
                  defaultBranchRef { target { ... on Commit { history(first: 5) { nodes { committedDate } } } } }
                }
              }
              contributionsCollection {
                totalPullRequestContributions
                totalPullRequestReviewContributions
                contributionCalendar {
                  totalContributions
                  weeks { contributionDays { contributionCount weekday } }
                }
              }
            }
          }
        `,
                variables: { username: USERNAME },
            }),
        });

        const json = await response.json();
        const u = json?.data?.user;
        const cc = u?.contributionsCollection;
        const repos = u?.repositories?.nodes || [];
        scanned = repos.length;

        const langTotals: Record<string, number> = {};
        let totalBytes = 0;
        repos.forEach((r: any) => {
            r.languages?.edges?.forEach((e: any) => {
                langTotals[e.node.name] =
                    (langTotals[e.node.name] || 0) + e.size;
                totalBytes += e.size;
            });
        });
        if (totalBytes > 0) {
            languages = Object.entries(langTotals)
                .map(([name, bytes]) => ({
                    name,
                    share: Math.round((bytes / totalBytes) * 100),
                }))
                .filter((l) => l.share > 0)
                .sort((a, b) => b.share - a.share)
                .slice(0, 5);
        }

        // most recent activity across repos: newest default-branch commit OR last push
        // (pushedAt catches commits on non-default branches too)
        repos.forEach((r: any) => {
            r.defaultBranchRef?.target?.history?.nodes?.forEach((c: any) => {
                const dt = new Date(c.committedDate);
                if (!lastCommit || dt > lastCommit) lastCommit = dt;
            });
            if (r.pushedAt) {
                const p = new Date(r.pushedAt);
                if (!lastCommit || p > lastCommit) lastCommit = p;
            }
        });

        if (cc?.contributionCalendar) {
            const cal = cc.contributionCalendar;
            const allDays = cal.weeks.flatMap((w: any) => w.contributionDays);
            let run = 0,
                longest = 0,
                spike = 0;
            const weekday = Array(7).fill(0);
            allDays.forEach((d: any) => {
                const c = d.contributionCount;
                if (c > spike) spike = c;
                weekday[d.weekday] += c;
                if (c > 0) {
                    run++;
                    if (run > longest) longest = run;
                } else run = 0;
            });
            const weekend = weekday[0] + weekday[6];
            const week =
                weekday.reduce((a: number, b: number) => a + b, 0) - weekend;
            velocity = {
                yearly: cal.totalContributions,
                spike,
                longestStreak: longest,
                dayPreference:
                    weekend > week ? "Weekend Warrior" : "Mid-week Focus",
            };

            let off = 0,
                total = 0;
            repos.forEach((r: any) => {
                r.defaultBranchRef?.target?.history?.nodes?.forEach(
                    (c: any) => {
                        const m = c.committedDate?.match(/T(\d{2}):/);
                        const hr = m
                            ? parseInt(m[1], 10)
                            : new Date(c.committedDate).getHours();
                        total++;
                        if (hr >= 18 || hr < 6) off++;
                    },
                );
            });
            if (total > 0) rhythm.offHoursPct = Math.round((off / total) * 100);
        }

        const prs = cc?.totalPullRequestContributions || 0;
        const reviews = cc?.totalPullRequestReviewContributions || 0;
        let style = "Independent Craft";
        const tc = prs + reviews;
        if (tc > 0)
            style =
                reviews / tc > 0.4
                    ? "Ecosystem Peer"
                    : prs / tc > 0.8
                      ? "Autonomous Builder"
                      : "Balanced Contributor";
        collab = { style, prs, reviews };
    } catch (err) {
        console.error("GitHub Insights fetch failed, using fallbacks:", err);
    }
}

const lastISO = lastCommit ? (lastCommit as Date).toISOString() : "";
const lastRel = lastCommit
    ? relTime(lastCommit as Date)
    : "Awaiting first push";
const lastAbs = lastCommit
    ? (lastCommit as Date).toLocaleString("en-US", {
          month: "short",
          day: "numeric",
          hour: "numeric",
          minute: "2-digit",
      })
    : "Push a repo to start the clock";
---

<section class="border-t border-line/70">
    <div class="max-w-5xl w-full mx-auto p-4 flex flex-col gap-6">
        <div
            class="rise p-8 rounded-2xl border border-[var(--color-line)] bg-[var(--color-paper-2)] shadow-[0_4px_20px_-4px_rgba(27,23,20,0.03)] hover:shadow-[0_8px_30px_-4px_rgba(27,23,20,0.06)] transition-all duration-500 flex flex-col justify-between group"
        >
            <div>
                <div
