                            width="22"
                            height="22"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            ><path
                                d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 .1.8 1.7 2.6 1.3.1-.7.4-1.2.7-1.5-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11 11 0 0 1 6 0C18 4.6 19 4.9 19 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"
                            ></path></svg
                        >
                    </div>
                </div>

                <div
                    class="w-full h-3 bg-[var(--color-paper)] rounded-full overflow-hidden flex mb-6 p-[2px] border border-[var(--color-line)]"
                >
                    {
                        languages.map((item, idx) => (
                            <div
                                class={`h-full first:rounded-l-full last:rounded-r-full ${idx === 0 ? "bg-[var(--color-coral)]" : idx === 1 ? "bg-[var(--color-cobalt)]" : "bg-[var(--color-ink-soft)] opacity-60"}`}
                                style={`width:${item.share}%`}
                            />
                        ))
                    }
                    {
                        languages.length === 0 && (
                            <div class="h-full w-full bg-[var(--color-ink-soft)] opacity-20" />
                        )
                    }
                </div>

                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3">
                    {
                        languages.map((item, idx) => (
                            <li class="flex items-center justify-between text-base border-b border-[var(--color-line)] border-dotted pb-1.5">
                                <div class="flex items-center gap-2.5">
                                    <span
                                        class={`w-2 h-2 rounded-full ${idx === 0 ? "bg-[var(--color-coral)]" : idx === 1 ? "bg-[var(--color-cobalt)]" : "bg-[var(--color-ink-soft)] opacity-60"}`}
                                    />
                                    <span class="font-medium text-[var(--color-ink)]">
                                        {item.name}
                                    </span>
                                </div>
                                <span class="font-mono text-sm text-[var(--color-ink-soft)] font-medium">
                                    {item.share}%
                                </span>
                            </li>
                        ))
                    }
                    {
                        languages.length === 0 && (
                            <li class="font-mono text-sm text-[var(--color-ink-soft)] opacity-60">
                                No repos visible to this token yet — check the
                                token's repo access.
                            </li>
                        )
                    }
                </ul>
            </div>
            <div
                class="mt-8 pt-3 border-t border-[var(--color-line)] border-dashed flex justify-between font-mono text-[9px] text-[var(--color-ink-soft)] opacity-50"
            >
                <span class="flex items-center gap-1.5"
                    ><span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Live
                    API feed</span
                >
                <span>🔒 Repo details hidden</span>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- LAST COMMIT — the live, interactive card -->
            <div
                id="last-commit"
                data-iso={lastISO}
                class="rise [animation-delay:80ms] p-5 rounded-2xl border border-[var(--color-line)] bg-[var(--color-paper-2)] shadow-[0_4px_20px_-4px_rgba(27,23,20,0.03)] hover:shadow-[0_8px_30px_-4px_rgba(27,23,20,0.06)] transition-all duration-500 flex flex-col"
            >
                <div
                    class="flex items-center justify-between mb-3 border-b border-[var(--color-line)] pb-2"
                >
                    <span
                        class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-ink-soft)] opacity-75"
                        >Pulse</span
                    >
                    <span
                        class="w-2 h-2 rounded-full bg-[var(--color-coral)] pulse-dot"
                    ></span>
                </div>
                <span
                    class="font-mono text-[10px] text-[var(--color-ink-soft)] opacity-60 uppercase tracking-wider"
                    >Last Commit</span
                >
                <p
                    data-rel
                    class="font-display text-2xl font-bold text-[var(--color-ink)] leading-tight mt-1"
                >
                    {lastRel}
                </p>
                <span
                    data-abs
                    class="font-mono text-[10px] text-[var(--color-cobalt)] bg-[var(--color-paper)] border border-[var(--color-line)] px-1.5 py-0.5 rounded mt-2 inline-block w-fit"
                    >{lastAbs}</span
                >
                <span
                    class="font-mono text-[9px] text-[var(--color-ink-soft)] opacity-50 mt-auto pt-3"
                    >Counting up live</span
                >
            </div>

            <div
                class="rise [animation-delay:140ms] p-5 rounded-2xl border border-[var(--color-line)] bg-[var(--color-paper-2)] shadow-[0_4px_20px_-4px_rgba(27,23,20,0.03)] hover:shadow-[0_8px_30px_-4px_rgba(27,23,20,0.06)] transition-all duration-500"
            >
                <div
                    class="flex items-center justify-between mb-3 border-b border-[var(--color-line)] pb-2"
                >
                    <span
                        class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-ink-soft)] opacity-75"
                        >Work Patterns</span
                    >
                    <div class="text-[var(--color-cobalt)] opacity-70">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="15"
                            height="15"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><circle cx="12" cy="12" r="10"></circle><polyline
                                points="12 6 12 12 16 14"></polyline></svg
                        >
                    </div>
                </div>
                <span
                    class="font-mono text-[10px] text-[var(--color-ink-soft)] opacity-60"
                    >Peak Activity Zone</span
                >
                <p
                    class="font-display text-xl font-bold text-[var(--color-ink)] leading-tight"
                >
                    {rhythm.peakWindow}
                </p>
                <span
                    class="font-mono text-[10px] text-[var(--color-cobalt)] bg-[var(--color-paper)] border border-[var(--color-line)] px-1.5 py-0.5 rounded mt-1 inline-block"
                    >{rhythm.hours}</span
                >
                <div class="mt-4">
                    <div
                        class="flex justify-between font-mono text-[9px] text-[var(--color-ink-soft)] mb-1"
                    >
                        <span>After-hours focus</span><span
                            class="font-bold text-[var(--color-ink)]"
                            >{rhythm.offHoursPct}%</span
                        >
                    </div>
                    <div
                        class="w-full h-1.5 bg-[var(--color-paper)] rounded-full overflow-hidden border border-[var(--color-line)]"
                    >
                        <div
                            class="h-full bg-[var(--color-ink)] rounded-full"
                            style={`width:${rhythm.offHoursPct}%`}
                        >
                        </div>
                    </div>
                </div>
            </div>

            <!-- COMMIT VELOCITY -->
            <div
                class="rise [animation-delay:200ms] p-5 rounded-2xl border border-[var(--color-line)] bg-[var(--color-paper-2)] shadow-[0_4px_20px_-4px_rgba(27,23,20,0.03)] hover:shadow-[0_8px_30px_-4px_rgba(27,23,20,0.06)] transition-all duration-500"
            >
                <div
                    class="flex items-center justify-between mb-3 border-b border-[var(--color-line)] pb-2"
                >
                    <span
                        class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-ink-soft)] opacity-75"
                        >Velocity</span
                    >
                    <div class="text-[var(--color-coral)] opacity-70">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="15"
                            height="15"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path d="M14.5 4l-5 16M18 16l4-4-4-4M6 8l-4 4 4 4"
                            ></path></svg
                        >
                    </div>
                </div>
                <ul class="flex flex-col gap-2.5 mt-1">
                    <li
                        class="flex items-center justify-between font-body text-sm"
                    >
                        <span class="text-[var(--color-ink-soft)]"
                            >Yearly Volume</span
                        >
                        <span
                            class="font-display font-bold text-[var(--color-ink)]"
                            >{velocity.yearly}</span
                        >
                    </li>
                    <li
                        class="flex items-center justify-between font-body text-sm"
                    >
                        <span class="text-[var(--color-ink-soft)]"
                            >Max Daily Spike</span
                        >
                        <span
                            class="font-display font-bold text-[var(--color-coral)]"
                            >+{velocity.spike} ops</span
                        >
                    </li>
                    <li
                        class="flex items-center justify-between font-body text-sm"
                    >
                        <span class="text-[var(--color-ink-soft)]"
                            >Longest Streak</span
                        >
                        <span
                            class="font-display font-bold text-[var(--color-ink)]"
                            >{velocity.longestStreak} days</span
                        >
                    </li>
                    <li
                        class="flex items-center justify-between font-body text-sm"
                    >
                        <span class="text-[var(--color-ink-soft)]"
                            >Calendar Mode</span
                        >
                        <span
                            class="font-mono text-[10px] text-[var(--color-ink)] bg-[var(--color-paper)] border border-[var(--color-line)] px-1.5 py-0.5 rounded"
                            >{velocity.dayPreference}</span
                        >
                    </li>
                </ul>
            </div>

            <div
                class="rise [animation-delay:260ms] p-5 rounded-2xl border border-[var(--color-line)] bg-[var(--color-paper-2)] shadow-[0_4px_20px_-4px_rgba(27,23,20,0.03)] hover:shadow-[0_8px_30px_-4px_rgba(27,23,20,0.06)] transition-all duration-500 flex flex-col"
            >
                <div
                    class="flex items-center justify-between mb-3 border-b border-[var(--color-line)] pb-2"
                >
                    <span
                        class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-ink-soft)] opacity-75"
                        >Team Role</span
                    >
                    <div class="text-[var(--color-cobalt)] opacity-70">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="15"
                            height="15"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                            ></path><circle cx="9" cy="7" r="4"></circle><path
                                d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"
                            ></path></svg
                        >
                    </div>
                </div>
                <span
                    class="font-mono text-[10px] text-[var(--color-ink-soft)] opacity-60"
                    >Operational Profile</span
                >
                <p
                    class="font-display text-xl font-bold text-[var(--color-ink)] leading-tight"
                >
                    {collab.style}
                </p>
                <div class="flex gap-2 mt-4">
                    <div
                        class="flex-1 bg-[var(--color-paper)] border border-[var(--color-line)] rounded-lg px-2 py-1.5 text-center"
                    >
                        <span
                            class="block text-[8px] font-mono text-[var(--color-ink-soft)] opacity-50 uppercase tracking-wider"
                            >PRs</span
                        >
                        <span
                            class="text-base font-display font-bold text-[var(--color-coral)]"
                            >{collab.prs}</span
                        >
                    </div>
                    <div
                        class="flex-1 bg-[var(--color-paper)] border border-[var(--color-line)] rounded-lg px-2 py-1.5 text-center"
                    >
                        <span
                            class="block text-[8px] font-mono text-[var(--color-ink-soft)] opacity-50 uppercase tracking-wider"
                            >Reviews</span
                        >
                        <span
                            class="text-base font-display font-bold text-[var(--color-cobalt)]"
                            >{collab.reviews}</span
                        >
                    </div>
                </div>
                <span
                    class="font-mono text-[9px] text-[var(--color-ink-soft)] opacity-50 mt-auto pt-3 text-center"
                    >{YEAR} account-wide interactions</span
                >
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes ghPulse {
        0%,
        100% {
            opacity: 1;
            transform: scale(1);
        }
        50% {
            opacity: 0.35;
            transform: scale(0.7);
        }
    }
    .pulse-dot {
        animation: ghPulse 1.8s ease-in-out infinite;
    }
    @media (prefers-reduced-motion: reduce) {
        .pulse-dot {
            animation: none;
        }
    }
</style>

<script>
    function relTime(from: Date): string {
        const s = Math.max(0, Math.floor((Date.now() - from.getTime()) / 1000));
        if (s < 45) return "just now";
        const m = Math.floor(s / 60);
        if (s < 90) return "1 minute ago";
        if (m < 60) return `${m} minutes ago`;
        const h = Math.floor(m / 60);
        if (m < 90) return "1 hour ago";
        if (h < 24) return `${h} hours ago`;
        const d = Math.floor(h / 24);
        if (h < 36) return "1 day ago";
        if (d < 7) return `${d} days ago`;
        const w = Math.floor(d / 7);
        if (d < 11) return "1 week ago";
        if (w < 5) return `${w} weeks ago`;
        const mo = Math.floor(d / 30);
        if (d < 45) return "1 month ago";
        if (mo < 12) return `${mo} months ago`;
        const y = Math.floor(d / 365);
        return y <= 1 ? "1 year ago" : `${y} years ago`;
    }

    const card = document.getElementById("last-commit");
    const iso = card?.getAttribute("data-iso");
    const relEl = card?.querySelector("[data-rel]");
    if (card && iso && relEl) {
        const from = new Date(iso);
        const tick = () => {
            relEl.textContent = relTime(from);
        };
        tick();
        setInterval(tick, 20000); 
    }
</script>
