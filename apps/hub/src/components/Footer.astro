  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-10 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="font-display text-lg font-medium text-ink">
        AltSource <span class="text-coral">Hub</span>
      </p>
      <p class="mt-1 text-sm text-ink-soft">
        A yearly library of things I’m exploring, using, and recommending.
      </p>
    </div>

    <div class="font-mono text-xs uppercase tracking-wider text-ink-soft">
      © {year} Bljeona 
    </div>
  </div>
</footer>