---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import Timetracker from "../../../components/widgets/Timetracker.astro";
---

<BaseLayout>
    <div
        style="text-align: center; margin: 24px 0 12px; font-size: 13px; font-weight: 600; color: var(--muted);"
    >
        Crafted by <a
            href="https://bljeona.com"
            target="_blank"
            style="color: var(--red); text-decoration: none; border-bottom: 1.5px solid transparent; transition: 0.15s;"
            onmouseover="this.style.borderBottomColor='var(--red)'"
            onmouseout="this.style.borderBottomColor='transparent'"
            >bljeona.com</a
        >
    </div>
    <main>
        <Timetracker />
    </main>
</BaseLayout>
